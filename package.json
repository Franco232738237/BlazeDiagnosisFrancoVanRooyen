{
  "name": "blaze-diagnostics",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @blaze-diagnostics/web dev",
    "build": "pnpm --filter @blaze-diagnostics/web build",
    "lint": "pnpm --filter @blaze-diagnostics/web lint",
    "format": "pnpm --filter @blaze-diagnostics/web format",
    "typecheck": "pnpm --filter @blaze-diagnostics/web typecheck",
    "typegen": "pnpm --filter @blaze-diagnostics/web typegen",
    "test:web": "pnpm --filter @blaze-diagnostics/web test",
    "test": "pnpm --filter @blaze-diagnostics/web test"
  },
  "devDependencies": {
    "prettier": "latest",
    "prettier-plugin-organize-imports": "latest"
  }
}
